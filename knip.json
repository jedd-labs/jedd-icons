{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "tags": ["-lintignore"],
  "workspaces": {
    ".": {},
    "packages/*": {},
    "packages/react": {
      "entry": ["src/fill.ts"]
    },
    "packages/core": {
      "entry": ["src/fill.ts"]
    },
    "apps/www-docs": {
      "entry": [
        "src/router.tsx",
        "src/start.ts",
        "vite.config.ts",
        "source.config.ts"
      ],
      "vite": false
    },
    "tools/*": {
      "entry": ["*.ts"]
    }
  }
}
