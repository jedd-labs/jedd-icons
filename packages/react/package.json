{
  "name": "@jedd-icons/react",
  "version": "0.0.1",
  "description": "Jedd icons for React.",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./fill": {
      "types": {
        "import": "./dist/fill.d.mts",
        "require": "./dist/fill.d.cts"
      },
      "import": "./dist/fill.mjs",
      "require": "./dist/fill.cjs"
    }
  },
  "typesVersions": {
    "*": {
      "fill": [
        "./dist/fill.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "gen": "tsx ../../tools/build-icons/build.ts",
    "build": "pnpm gen && tsdown --config-loader tsx",
    "dev": "pnpm gen && tsdown --config-loader tsx --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^17 || ^18 || ^19"
  },
  "devDependencies": {
    "@jedd-icons/shared": "workspace:*",
    "@types/react": "catalog:",
    "react": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
